    {
      "name": "7 — [DEMO] Virtual Thread Stress Testi — 20 Eşzamanlı İstek (FIX #1)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.globals.set('modern_times', JSON.stringify([]));",
              "const url = pm.variables.get('baseUrl') + '/api/documents/sign';",
              "const customers = [",
              "  ['10000000001','Ayşe Arslan'],['20000000002','Burak Çelik'],",
              "  ['30000000003','Can Erdoğan'],['40000000004','Deniz Fırat'],",
              "  ['50000000005','Ece Güneş'],['60000000006','Furkan Hızlı'],",
              "  ['70000000007','Gizem İpek'],['80000000008','Hakan Işık'],",
              "  ['90000000009','İrem Karaca'],['11111111110','Jale Koç'],",
              "  ['22222222221','Kemal Liman'],['33333333332','Lale Mercan'],",
              "  ['44444444443','Murat Narin'],['55555555554','Nalan Osman'],",
              "  ['66666666665','Onur Pınar'],['77777777776','Pınar Rüzgar'],",
              "  ['88888888887','Rıza Sarı'],['99999999998','Selin Taş'],",
              "  ['12121212129','Tolga Uzun'],['21212121210','Ümit Yıldız']",
              "];",
              "for (let i = 0; i < 19; i++) {",
              "  const [cid, cname] = customers[i];",
              "  const body = JSON.stringify({ templateId: (i % 3) + 1, customerId: cid, customerName: cname });",
              "  const start = Date.now();",
              "  pm.sendRequest({ url, method: 'POST',",
              "    header: [{ key: 'Content-Type', value: 'application/json' }],",
              "    body: { mode: 'raw', raw: body } },",
              "    function(err, res) {",
              "      const times = JSON.parse(pm.globals.get('modern_times') || '[]');",
              "      times.push({ id: i + 1, time: res ? res.responseTime : 9999,",
              "        status: err ? 'HATA' : res.code, isError: !!err });",
              "      pm.globals.set('modern_times', JSON.stringify(times));",
              "    }",
              "  );",
              "}",
              "console.log('>>> 19 istek arka planda ateşlendi — ana istek #20 gönderiliyor...');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const mainTime = pm.response.responseTime;",
              "const allTimes = JSON.parse(pm.globals.get('modern_times') || '[]');",
              "allTimes.push({ id: 20, time: mainTime, status: pm.response.code, isError: false });",
              "allTimes.sort((a, b) => a.id - b.id);",
              "const maxTime = Math.max(...allTimes.map(t => t.time));",
              "const avgTime = Math.round(allTimes.reduce((s, t) => s + t.time, 0) / allTimes.length);",
              "",
              "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
              "pm.test('20. istek de hızlı yanıtladı (Virtual Threads bloklamadı)', () => {",
              "  pm.expect(mainTime).to.be.below(2000);",
              "});",
              "",
              "const template = `",
              "<style>",
              "body{font-family:Arial,sans-serif;padding:20px;background:#1e1e2e;color:#cdd6f4;}",
              "h2{color:#89b4fa;margin-bottom:4px;}",
              ".subtitle{color:#a6adc8;font-size:13px;margin-bottom:16px;}",
              ".summary{display:flex;gap:16px;margin-bottom:20px;}",
              ".stat{background:#313244;padding:12px 20px;border-radius:8px;text-align:center;}",
              ".num{font-size:26px;font-weight:bold;color:#a6e3a1;}",
              ".lbl{font-size:11px;color:#a6adc8;margin-top:2px;}",
              ".row{display:flex;align-items:center;margin:5px 0;}",
              ".lbl2{width:90px;font-size:12px;color:#cdd6f4;}",
              ".bar{height:26px;border-radius:4px;display:flex;align-items:center;",
              "padding:0 10px;font-size:11px;font-weight:bold;color:#fff;min-width:50px;}",
              ".ok{background:#40a02b;} .mid{background:#df8e1d;}",
              ".tag{margin-left:10px;font-size:11px;color:#a6adc8;}",
              ".compare{margin-top:20px;padding:14px;background:#313244;border-radius:8px;}",
              ".legacy-bar{height:32px;background:#e64553;border-radius:4px;display:flex;",
              "align-items:center;padding:0 12px;color:#fff;font-weight:bold;font-size:13px;width:420px;}",
              ".modern-bar{height:32px;background:#40a02b;border-radius:4px;display:flex;",
              "align-items:center;padding:0 12px;color:#fff;font-weight:bold;font-size:13px;}",
              ".clbl{font-size:12px;color:#a6adc8;margin-bottom:4px;}</style>",
              "<body>",
              "<h2>🧵 Virtual Thread Stress Testi — 20 Eşzamanlı İstek</h2>",
              "<div class='subtitle'>FIX #1: MAX_THREADS=10 sınırı YOK — tüm istekler aynı anda işlendi</div>",
              "<div class='summary'>",
              "<div class='stat'><div class='num'>{{total}}</div><div class='lbl'>Toplam İstek</div></div>",
              "<div class='stat'><div class='num'>{{avgTime}}ms</div><div class='lbl'>Ortalama Süre</div></div>",
              "<div class='stat'><div class='num'>{{maxTime}}ms</div><div class='lbl'>Max Süre</div></div>",
              "<div class='stat'><div class='num'>{{success}}</div><div class='lbl'>Başarılı</div></div>",
              "</div>",
              "{{#each rows}}<div class='row'>",
              "<div class='lbl2'>İstek #{{id}}</div>",
              "<div class='bar {{cls}}' style='width:{{w}}px'>{{time}}ms</div>",
              "<div class='tag'>{{tag}}</div></div>{{/each}}",
              "<div class='compare'>",
              "<div style='font-weight:bold;color:#89b4fa;margin-bottom:10px;'>⚡ Legacy vs Modern Karşılaştırması (20 eşzamanlı istek)</div>",
              "<div class='clbl'>Legacy — Thread havuzu dolunca 11-20. istekler sıra bekledi (~36000ms+)</div>",
              "<div class='legacy-bar'>❌ Legacy: ~3600ms × bekleyen istekler = dakikalar</div>",
              "<div style='height:8px;'></div>",
              "<div class='clbl'>Modern — Virtual Threads, tüm istekleri eşzamanlı işledi</div>",
              "<div class='modern-bar' style='width:{{modernBarW}}px'>✅ Modern: {{avgTime}}ms ortalama</div>",
              "</div></body>`;",
              "",
              "const rows = allTimes.map(t => ({",
              "  id: t.id, time: t.time,",
              "  w: Math.max(50, Math.round((t.time / maxTime) * 380)),",
              "  cls: t.time > 1500 ? 'mid' : 'ok',",
              "  tag: t.id === 20 ? '← Ana istek' : (t.isError ? '❌ Hata' : '✅')",
              "}));",
              "",
              "pm.visualizer.set(template, {",
              "  total: allTimes.length,",
              "  avgTime, maxTime,",
              "  success: allTimes.filter(t => !t.isError).length,",
              "  rows,",
              "  modernBarW: Math.max(80, Math.round((avgTime / 3600) * 420))",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/documents/sign",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"templateId\": 1,\n  \"customerId\": \"99988877760\",\n  \"customerName\": \"Stress Test 20 (Ana İstek)\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "description": "Çalıştır → Pre-request Script 19 isteği arka planda ateşler → Ana istek #20 gönderilir.\n\n📊 Sonucu görmek için: Response altında 'Visualize' sekmesine tıkla!\n\nLegacy'de 11. istek thread havuzu dolduğu için sıra beklerdi.\nModern'de Virtual Threads sayesinde tüm 20 istek aynı anda işlenir — hiçbiri beklemez."
      }
    }
  ]
}
